{
  "name": "react-fluid-table",
  "version": "1.5.3",
  "description": "A React table inspired by @tanstack/react-virtual",
  "author": "Mckervin Ceme <mckervinc@live.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mckervinc/react-fluid-table.git"
  },
  "homepage": "https://mckervinc.github.io/react-fluid-table",
  "main": "dist/index.js",
  "module": "dist/index.es.js",
  "jsnext:main": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.js"
    },
    "./dist/index.css": "./dist/index.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "reactjs",
    "table",
    "window",
    "fluid",
    "virtualized",
    "list",
    "scrolling",
    "frozen"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "concurrently \"yarn dev\" \"yarn --cwd example dev\"",
    "site:build": "yarn --cwd example install && yarn --cwd example build",
    "prepublishOnly": "yarn build"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/react": "^19",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "concurrently": "^9.2.3",
    "eslint": "9.29.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "gh-pages": "^6.3.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.0",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.14.4",
    "react-resize-detector": "^12.3.0"
  }
}
